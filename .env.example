# -----------------------------------------------------------------------------
# .env.example — committed template documenting expected env vars.
# Real values live in `.env.local` (gitignored via the `.env.*` rule in
# .gitignore; verify with `git check-ignore .env.local` exit 0).
# -----------------------------------------------------------------------------

# Phase 7 (FN-07) — App Check + reCAPTCHA Enterprise
# ---------------------------------------------------------------------------
# Production site key issued by Firebase Console App Check enrolment.
# PER-ENV: do NOT share keys across dev / staging / prod.
# Domain-bound public identifier (NOT a secret — accept disposition
# T-07-03-02). The operational discipline of one-key-per-env exists for
# clean revocation, not for confidentiality.
VITE_RECAPTCHA_ENTERPRISE_SITE_KEY=6L_REPLACE_ME

# Debug token for local Vite dev server / CI / scratch-project bypasses.
# Generate via Firebase Console -> App Check -> Apps -> ⋮ -> "Manage debug
# tokens" -> "Add debug token". One token per developer / CI runner — do NOT
# share. NEVER commit a real token (Pitfall 8 mitigation; T-07-03-04 mitigate).
# Vite tree-shakes the DEV branch from production bundles, so this var is
# only read in `import.meta.env.DEV` mode.
VITE_APPCHECK_DEBUG_TOKEN=00000000-0000-0000-0000-000000000000
