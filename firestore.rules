rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Auth predicates (D-14 / Pitfall 2) ────────────────────────────
    function isAuthed() {
      return request.auth != null
        && request.auth.token.email_verified == true
        && request.auth.token.firebase.sign_in_provider != "anonymous";
    }
    function role()  { return request.auth.token.role; }
    function orgId() { return request.auth.token.orgId; }
    function isInternal() { return isAuthed() && role() in ["internal", "admin"]; }
    function isAdmin()    { return isAuthed() && role() == "admin"; }
    function inOrg(o)     { return isAuthed() && (isInternal() || orgId() == o); }

    // ── Document predicates ───────────────────────────────────────────
    function notDeleted(r) { return !("deletedAt" in r) || r.deletedAt == null; }
    function isOwnAuthor(r){ return r.authorId == request.auth.uid; }

    // ── Mutation whitelist (D-15 / Pitfall 3 / RULES-02) ──────────────
    // Use Map.get(field, null) instead of bracket access so the comparison
    // doesn't throw on docs that lack the field on either side. The prior
    // bracket-access form errored when either request.resource.data or
    // resource.data was missing the field — CEL surfaces "no such key" as
    // an error that short-circuits the whole `allow update` clause to false,
    // even when both sides were missing the field (which logically should
    // be "equal — no change"). Hit in prod when admin tried to update an
    // org doc that lacked an explicit `orgId` field (we found this in prod
    // diagnostic 2026-05-22). Rules-tests never caught it because the seed
    // always populated `orgId` + `createdAt` on every fixture doc.
    function immutable(field) {
      return request.resource.data.get(field, null) == resource.data.get(field, null);
    }
    function mutableOnly(fields) {
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly(fields);
    }

    // ── Rate-limit predicates (FN-09 / Pitfall 9 / Phase 7 Wave 4) ────
    // 60-second buckets keyed off request.time (server-controlled timestamp).
    // Returns the windowStart as a string so it composes with bucket doc ids.
    function rateLimitWindow() {
      return string(int(request.time.toMillis() / 60000) * 60000);
    }
    // Composed into messages + comments create predicates. Allows the write
    // IF either no bucket exists for the current window, OR the current
    // bucket count is < 30. Costs 1 Firestore get() per evaluation
    // (Pitfall 4 — single-get budget). MUST be the LAST conjunct so the
    // cheap predicates (inOrg, authorId == uid) short-circuit first.
    function rateLimitOk(uid) {
      return !exists(/databases/$(database)/documents/rateLimits/$(uid)/buckets/$(rateLimitWindow()))
        || get(/databases/$(database)/documents/rateLimits/$(uid)/buckets/$(rateLimitWindow())).data.count < 30;
    }

    // ── orgs/{orgId} parent doc ───────────────────────────────────────
    match /orgs/{orgId} {
      // Staff keep read access to soft-deleted orgs (roster hides them, but the
      // admin can see/restore them); clients lose access once tombstoned. An
      // unconstrained orgs list query would otherwise be denied wholesale the
      // moment any org carries deletedAt (rules are filters-of-last-resort), so
      // this staff bypass is what keeps the admin org-list snapshot working.
      allow read:   if inOrg(orgId) && (isInternal() || notDeleted(resource.data));
      allow create: if isInternal();
      allow update: if isInternal()
                    && immutable("orgId")
                    && immutable("createdAt");
      allow delete: if false;  // soft-delete via Cloud Function only

      // ── responses subcollection ─────────────────────────────────────
      // Writes are staff-only (2026-07, client view-only diagnostic):
      // clients read prior scoring but can no longer submit or edit it.
      match /responses/{respId} {
        allow read:   if inOrg(orgId);
        allow create: if isInternal()
                      && request.resource.data.userId == request.auth.uid;
        allow update: if isInternal()
                      && immutable("userId")
                      && immutable("orgId")
                      && mutableOnly(["values", "updatedAt", "legacyAppUserId"]);
        allow delete: if false;
      }

      // ── comments subcollection (FN-09 rate-limit composed at create) ─
      match /comments/{cmtId} {
        allow read:   if inOrg(orgId)
                      && notDeleted(resource.data)
                      && (!("internalOnly" in resource.data) || !resource.data.internalOnly || isInternal());
        allow create: if inOrg(orgId)
                      && request.resource.data.authorId == request.auth.uid
                      && rateLimitOk(request.auth.uid);
        allow update: if false;
        allow delete: if false;
      }

      // ── actions subcollection ───────────────────────────────────────
      match /actions/{actId} {
        allow read:   if inOrg(orgId) && notDeleted(resource.data);
        allow create: if inOrg(orgId);
        allow update: if inOrg(orgId)
                      && immutable("orgId")
                      && immutable("createdAt")
                      && mutableOnly(["status", "ownerId", "title", "description", "dueAt", "updatedAt"]);
        allow delete: if false;
      }

      // ── documents subcollection ─────────────────────────────────────
      match /documents/{docId} {
        allow read:   if inOrg(orgId) && notDeleted(resource.data);
        allow create: if inOrg(orgId);
        allow update: if false;
        allow delete: if false;
      }

      // ── messages subcollection (FN-09 rate-limit composed at create) ─
      match /messages/{msgId} {
        allow read:   if inOrg(orgId) && notDeleted(resource.data);
        allow create: if inOrg(orgId)
                      && request.resource.data.authorId == request.auth.uid
                      && rateLimitOk(request.auth.uid);
        allow update: if false;
        // Hard-delete (2026-07 client request): a client removes their OWN
        // message; internal/admin staff remove ANY (mistaken/wrong content).
        // Matches the UI gate `canDelete = isSelf || !isClientView(user)`.
        allow delete: if inOrg(orgId)
                      && (isOwnAuthor(resource.data) || isInternal());
      }

      // ── readStates subcollection (DATA-07 H7 fix lands in Wave 4) ───
      match /readStates/{userId} {
        allow read:   if inOrg(orgId)
                      && (request.auth.uid == userId || isInternal());
        allow create: if inOrg(orgId) && request.auth.uid == userId;
        allow update: if inOrg(orgId) && request.auth.uid == userId
                      && mutableOnly(["pillarReads", "chatLastRead"]);
        allow delete: if false;
      }
    }

    // ── users/{uid} ───────────────────────────────────────────────────
    match /users/{uid} {
      allow read:   if isAuthed() && (request.auth.uid == uid || isInternal());
      allow create: if false;  // server-only; bootstrap migration in Phase 6
      allow update: if false;  // server-only via setClaims callable (Phase 6)
      allow delete: if false;
    }

    // ── internalAllowlist/{email} ─────────────────────────────────────
    match /internalAllowlist/{email} {
      allow read:  if isAdmin();
      allow write: if isAdmin();
    }

    // ── orgSecrets/{orgId} (staff-viewable plaintext company passphrase) ──
    // Recoverable copy of the org's client passphrase so internal/admin staff
    // can view it later. The org doc's clientPassphraseHash stays the verify
    // source of truth (inviteClient contract). This MUST be its own top-level
    // collection — NOT a field on orgs/{orgId}, which is client-readable via
    // inOrg() — so a client (role "client") can never read the plaintext, even
    // for their own org. isInternal() = role in ["internal","admin"]; clients
    // fail it. Written client-side by staff via src/data/org-secrets.js.
    match /orgSecrets/{orgId} {
      allow read:   if isInternal();
      allow create: if isInternal();
      allow update: if isInternal();
      allow delete: if false;
    }

    // ── auditLog/{eventId} (AUDIT-07 / Pitfall 17) ────────────────────
    match /auditLog/{eventId} {
      allow read:  if isAdmin();   // internal CANNOT read own audit records
      allow write: if false;       // server-only via auditWrite callable (Phase 7)
    }

    // ── authFailureCounters/{ipHash} (Phase 9 Wave 5 / OBS-05 / Pattern 10) ───
    // Server-only rolling-window counter consumed by the auth-anomaly Slack
    // alert (functions/src/observability/authAnomalyAlert.ts). Same Pattern as
    // the auditLog block above (allow read+write: if false; Admin SDK is the
    // only writer — specifically the audit-alert-sa SA from Wave 6 / Plan
    // 09-05 SA inventory). Prevents client tampering that would bypass the
    // EXACTLY-ONCE Slack-fire guarantee (T-9-04-6 mitigation).
    match /authFailureCounters/{ipHash} {
      allow read:  if false;
      allow write: if false;
    }

    // ── softDeleted/{type}/items/{id} ─────────────────────────────────
    match /softDeleted/{type}/items/{id} {
      allow read:  if isAdmin();
      allow write: if false;       // server-only (Phase 8)
    }

    // ── redactionList/{userId} (GDPR-05 — Phase 8 Wave 4) ────────────────
    // Server-only writes via gdprEraseUser callable; admin-readable so
    // backup-rotation scripts (BACKUP-07 restore drill) can re-apply
    // tombstone tokens after database restore. Pitfall 17 — never client-writable.
    match /redactionList/{userId} {
      allow read:  if isAdmin();
      allow write: if false;
    }

    // ── rateLimits (FN-09 — replaces Phase 5 D-17 deny-block; Phase 7 W4) ─
    // Per-uid 60s sliding-window bucket. Self-readable for UI affordance
    // ("you've sent N/30"). Create requires count==1 + windowStart matches
    // server's current window. Update enforces monotonic +1 with hard cap 30.
    // Delete forbidden — buckets age out via scheduled cleanup (Phase 8+).
    match /rateLimits/{uid}/buckets/{windowStart} {
      allow read:   if isAuthed() && request.auth.uid == uid;
      allow create: if isAuthed() && request.auth.uid == uid
                    && windowStart == rateLimitWindow()
                    && request.resource.data.uid == uid
                    && request.resource.data.count == 1;
      allow update: if isAuthed() && request.auth.uid == uid
                    && immutable("uid")
                    && windowStart == rateLimitWindow()
                    && request.resource.data.count == resource.data.count + 1
                    && request.resource.data.count <= 30;
      allow delete: if false;
    }

    // ── roadmaps/{orgId} (top-level per ARCHITECTURE.md §4) ──────────
    // `months` and `quarters` are the tier-specific period arrays the renderRoadmap
    // view writes via setDoc(..., { merge: true }) on each drag-drop / outcome edit
    // (src/main.js periodsField() returns one of these per orgTier). `pillars` stays
    // in the whitelist for the documented per-pillar schema in ARCHITECTURE.md §4.
    match /roadmaps/{orgId} {
      allow read:   if inOrg(orgId);
      allow create: if inOrg(orgId);
      allow update: if inOrg(orgId)
                    && immutable("orgId")
                    && mutableOnly(["pillars", "months", "quarters", "updatedAt"]);
      allow delete: if false;
    }

    // ── funnels/{orgId} ───────────────────────────────────────────────
    // `years` (per-quarter numeric inputs) and `kpis` (custom row array) are the
    // fields renderFunnel writes via setDoc(..., { merge: true }). `stages` stays
    // in the whitelist for the documented stage schema in ARCHITECTURE.md §4.
    match /funnels/{orgId} {
      allow read:   if inOrg(orgId);
      allow create: if inOrg(orgId);
      allow update: if inOrg(orgId)
                    && immutable("orgId")
                    && mutableOnly(["stages", "years", "kpis", "updatedAt"]);
      allow delete: if false;
    }

    // ── funnelComments/{id} (orgId field per ARCHITECTURE.md §4) ─────
    match /funnelComments/{id} {
      allow read:   if inOrg(resource.data.orgId) && notDeleted(resource.data);
      allow create: if inOrg(request.resource.data.orgId)
                    && request.resource.data.authorId == request.auth.uid;
      allow update: if false;
      // Hard-delete (2026-07 client request): author removes their OWN funnel
      // comment; internal/admin staff remove ANY. Mirrors the messages rule.
      allow delete: if inOrg(resource.data.orgId)
                    && (isOwnAuthor(resource.data) || isInternal());
    }
  }
}
