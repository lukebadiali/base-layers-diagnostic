// Phase 6 Wave 5 Step 1 rehearsal — storage rollback target.
// Approximates the Apr-27-2026 minimal shape (single-block any-authed allow)
// captured in Phase 5 05-HUMAN-UAT.md. Transient — deployed only during
// the rehearsal to validate D-12's rollback path.

rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    match /{allPaths=**} {
      allow read, write: if request.auth != null;
    }
  }
}
