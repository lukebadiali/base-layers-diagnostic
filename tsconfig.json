{
  "compilerOptions": {
    "allowJs": true,
    "checkJs": true,
    "noEmit": true,
    "strict": true,
    "target": "es2020",
    "module": "esnext",
    "moduleResolution": "bundler",
    "skipLibCheck": true,
    "lib": ["es2020", "dom"],
    "baseUrl": ".",
    "ignoreDeprecations": "6.0"
  },
  "include": ["**/*.js", "**/*.d.ts"],
  "exclude": ["node_modules", "dist", "functions/lib", "coverage", "vite.config.js"]
}
